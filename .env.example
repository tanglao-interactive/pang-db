AWS_REGION=us-east-1
AMPLIFY_VPC_ID=vpc-xxxxxxxx
AMPLIFY_SUBNET_IDS=subnet-aaaaaaaa,subnet-bbbbbbbb
AMPLIFY_SECURITY_GROUP_IDS=sg-aaaaaaaa
DATABASE_SSL_MODE=require
DATABASE_SSL_CA_FILE=certs/rds/global-bundle.pem
# DATABASE_SSL_CA_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Use one of the following:
DATABASE_URL=postgres://username:password@hostname:5432/database?sslmode=verify-full&sslrootcert=certs/rds/global-bundle.pem
# DATABASE_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:my-rds-secret

# Optional override when the Next.js server should invoke the sandbox Lambda directly.
# Leave this unset to debug with a direct local DB connection instead of the Lambda path.
# AMPLIFY_DB_EXPLORER_FUNCTION_NAME=dbExplorer-dev
